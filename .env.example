# Postgres container
POSTGRES_DB=jobtrackr
POSTGRES_USER=jobtrackr_app
POSTGRES_PASSWORD=jobtrackr_app
POSTGRES_PORT=5432

# Spring Boot API
DB_HOST=localhost:5432
DB_NAME=jobtrackr
DB_USERNAME=jobtrackr_app
DB_PASSWORD=jobtrackr_app
JWT_SIGNING_KEY=change-me-to-a-long-random-local-secret-at-least-32-bytes
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=http://localhost:5173
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.eu.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jobtrackr-development
R2_SIGNED_URL_SECONDS=60

# CV generation (FastAPI service — Compose service `cv-generation`)
CV_GENERATION_PORT=8081
CV_GENERATION_SERVICE_BASE_URL=http://localhost:8081
CV_GENERATION_SERVICE_TOKEN=dev-service-token
CV_GENERATION_PROVIDER=gemini
CV_GENERATION_WORKER_CONCURRENCY=1
CV_GENERATION_REQUEST_TIMEOUT=5m
GOOGLE_AI_API_KEY=  # required when CV_GENERATION_PROVIDER=gemini
CV_GENERATION_MODEL_ID=gemini-3.1-flash-lite
CV_GENERATION_WORKFLOW_VERSION=cv-graph-v2
# GEMINI_API_KEY=

# Vite web app
VITE_API_ORIGIN=http://localhost:8080
VITE_API_MOCKING=true

# Cloud tunnel (nginx + ngrok) — applied by scripts/cloud-tunnel-up.sh
# VITE_API_MOCKING=false
# VITE_API_ORIGIN=
# JWT_REFRESH_COOKIE_SECURE=true

# Manual seed scripts only run for dev/local/cloud-agent.
JOBTRACKR_SEED_ENV=dev
